# Server
PORT=3001
NODE_ENV=development

# Security — generate a strong random value for production (e.g. openssl rand -hex 64)
SESSION_SECRET=dev-only-insecure-secret-change-in-production

# CORS — frontend origin for local dev (Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=

# Fine configuration (in IDR)
DENDA_PER_HARI=500
DENDA_RUSAK_RINGAN=2000
DENDA_RUSAK_BERAT=5000
